# Next.js environment variables
# Copy this file to .env.local and fill in the values.
# Run `npx convex dev` first — it writes CONVEX_DEPLOYMENT and NEXT_PUBLIC_CONVEX_URL automatically.

# Written by `npx convex dev` — do not edit manually
CONVEX_DEPLOYMENT=dev:your-deployment-name

# Convex deployment URL (written by `npx convex dev`)
NEXT_PUBLIC_CONVEX_URL=https://your-deployment-name.convex.cloud

# Public URL of the GitHub repository. Set this once the repo is public.
# The OpenSourceBanner only shows when this is set.
NEXT_PUBLIC_GITHUB_REPO_URL=

# Optional: set to true to enable the public /contact form UI for this deployment.
# The server-side DISCORD_CONTACT_WEBHOOK secret must also be configured.
NEXT_PUBLIC_CONTACT_FORM_ENABLED=false

# Optional: client-side PostHog analytics
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=
NEXT_PUBLIC_POSTHOG_HOST=/ingest

# Optional: client-side Sentry error reporting. Self-hosted deployments default to off.
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0
NEXT_PUBLIC_SENTRY_REPLAYS_SESSION_SAMPLE_RATE=0
NEXT_PUBLIC_SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE=0

# ---------------------------------------------------------------------------
# Convex backend secrets — set these via `npx convex env set KEY value`
# They are NOT read from .env.local at runtime; this block is for reference only.
# ---------------------------------------------------------------------------

# Google AI Studio API key (https://aistudio.google.com)
# Used for the AI coach (primary: gemini-3-flash-preview, fallback: gemini-2.5-flash)
# npx convex env set GOOGLE_GENERATIVE_AI_API_KEY your-key

# Public URL of this deployment — used by @convex-dev/auth for redirect URLs in emails
# npx convex env set SITE_URL http://localhost:3000  (or your production URL)

# RSA keypair for @convex-dev/auth JWT signing. Generate with:
#   export JWT_PRIVATE_KEY="$(openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048)"
#   npx convex env set JWT_PRIVATE_KEY -- "$JWT_PRIVATE_KEY"
#   npx convex env set JWKS -- "$(node -e '
#     const crypto = require("crypto");
#     const priv = crypto.createPrivateKey(process.env.JWT_PRIVATE_KEY);
#     const jwk = crypto.createPublicKey(priv).export({format: "jwk"});
#     jwk.kid = crypto.randomUUID();
#     process.stdout.write(JSON.stringify({keys:[{...jwk,use:"sig",alg:"RS256"}]}));
#   ')"

# Resend API key (https://resend.com) — used for password-reset OTP emails
# npx convex env set AUTH_RESEND_KEY re_your_key

# 64-char hex string (32 bytes) for encrypting Tonal OAuth tokens at rest
# Generate: openssl rand -hex 32
# npx convex env set TOKEN_ENCRYPTION_KEY your-64-char-hex

# Server-side pepper for HMAC-hashing email-change verification codes.
# Without this, the 8-digit code space is trivially brute-forceable if the
# emailChangeRequests table ever leaks. Any long random string works.
# Generate: openssl rand -hex 32
# npx convex env set EMAIL_CHANGE_CODE_PEPPER your-64-char-hex

# Optional: contact form destination webhook used by /contact
# npx convex env set DISCORD_CONTACT_WEBHOOK https://discord.com/api/webhooks/...

# Optional: operator notifications for signups / errors / Tonal connections
# npx convex env set DISCORD_WEBHOOK_URL https://discord.com/api/webhooks/...

# Optional: server-side PostHog analytics (product events only; AI tracing moved to Phoenix Cloud)
# npx convex env set POSTHOG_PROJECT_TOKEN your-posthog-project-token

# ---------------------------------------------------------------------------
# Phoenix Cloud — AI observability and eval platform.
# The AI coach streams OpenTelemetry traces to Phoenix Cloud for conversation
# capture, tool-call inspection, and eval runs. Sign up at https://phoenix.arize.com.
# ---------------------------------------------------------------------------
# Phoenix Cloud API key (from the Phoenix UI under Settings -> API Keys).
# npx convex env set PHOENIX_API_KEY your-phoenix-api-key

# Phoenix Cloud OTLP collector endpoint. Defaults to https://app.phoenix.arize.com.
# npx convex env set PHOENIX_COLLECTOR_ENDPOINT https://app.phoenix.arize.com

# Optional: human-readable project name that segments traces in the Phoenix UI.
# npx convex env set PHOENIX_PROJECT_NAME roni-coach

# Optional: alternate Phoenix host (for self-hosted or region-specific deployments).
# PHOENIX_COLLECTOR_ENDPOINT takes precedence when both are set.
# npx convex env set PHOENIX_HOST https://app.phoenix.arize.com

# Optional: disable BYOK enforcement and force the shared Gemini key for all users
# npx convex env set BYOK_DISABLED true

# Optional: temporary old key used only during TOKEN_ENCRYPTION_KEY rotation
# npx convex env set TOKEN_ENCRYPTION_KEY_OLD your-previous-64-char-hex

# ---------------------------------------------------------------------------
# Garmin Connect integration (optional — leave unset to disable Garmin)
# Consumer key + secret come from the Garmin Developer Portal app:
#   https://developerportal.garmin.com/user/me/apps?program=829
# Evaluation keys are rate-limited (100/partner/min, 200/user/day).
# npx convex env set GARMIN_CONSUMER_KEY your-consumer-key
# npx convex env set GARMIN_CONSUMER_SECRET your-consumer-secret
#
# Callback URL MUST match the URL registered in the Garmin Developer Portal.
# For local dev, use your Convex site URL + /garmin/oauth/callback:
# npx convex env set GARMIN_OAUTH_CALLBACK_URL https://your-deployment.convex.site/garmin/oauth/callback
#
# Shared secret required on every Garmin Push webhook URL:
#   https://your-deployment.convex.site/garmin/webhook/activities?secret=<secret>
# Generate: openssl rand -hex 32
# npx convex env set GARMIN_WEBHOOK_SECRET your-random-secret
#
# Temporary dev-only bypass for testing existing Garmin Portal URLs before
# adding the shared secret query param. Do not set this in production.
# npx convex env set GARMIN_ALLOW_UNAUTHENTICATED_WEBHOOKS true
#
# Optional: where the browser lands after the Garmin handshake completes.
# Defaults to SITE_URL, then localhost for dev. Use an absolute URL in prod.
# npx convex env set GARMIN_OAUTH_POST_REDIRECT_URL https://your-app.com/settings
