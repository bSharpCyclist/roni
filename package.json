{
  "name": "roni",
  "version": "0.8.0",
  "description": "Unofficial AI coach, compatible with Tonal fitness machines. Not affiliated with Tonal Systems, Inc.",
  "license": "MIT",
  "keywords": [
    "tonal",
    "fitness",
    "ai",
    "coach",
    "workout",
    "gemini",
    "convex",
    "nextjs"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JeffOtano/roni.git"
  },
  "homepage": "https://roni.coach",
  "bugs": {
    "url": "https://github.com/JeffOtano/roni/issues"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:analyze": "ANALYZE=true next build",
    "start": "next start",
    "lint": "eslint --max-warnings=0 .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "setup": "tsx scripts/setup.ts",
    "knip": "knip",
    "test:e2e": "playwright test",
    "ai:dataset": "tsx scripts/evals/phoenix/buildDataset.ts",
    "ai:eval:smoke": "tsx scripts/evals/phoenix/runPromptSmoke.ts",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,yml,yaml,css}": [
      "prettier --write"
    ],
    "*.{ts,tsx}": [
      "bash scripts/check-file-size.sh"
    ]
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.71",
    "@ai-sdk/google": "^3.0.64",
    "@ai-sdk/openai": "^3.0.53",
    "@ai-sdk/provider": "^3.0.8",
    "@ai-sdk/provider-utils": "^4.0.23",
    "@arizeai/phoenix-client": "^6.8.0",
    "@arizeai/phoenix-evals": "^1.0.2",
    "@arizeai/phoenix-otel": "^1.0.0",
    "@base-ui/react": "^1.4.0",
    "@convex-dev/agent": "^0.6.1",
    "@convex-dev/aggregate": "^0.2.1",
    "@convex-dev/auth": "^0.0.91",
    "@convex-dev/migrations": "^0.3.4",
    "@convex-dev/rate-limiter": "^0.3.2",
    "@convex-dev/workflow": "^0.3.11",
    "@convex-dev/workpool": "^0.4.6",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/sdk-trace-node": "^2.7.0",
    "@sentry/nextjs": "^10.50.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "ai": "^6.0.168",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "convex": "^1.36.1",
    "convex-helpers": "^0.1.115",
    "lucide-react": "^1.11.0",
    "next": "^16.2.4",
    "posthog-js": "^1.372.1",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.5.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.4.4",
    "@edge-runtime/vm": "^5.0.0",
    "@next/bundle-analyzer": "^16.2.4",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.5",
    "convex-test": "^0.0.50",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.4",
    "husky": "^9.1.7",
    "jsdom": "^29.1.0",
    "knip": "^6.7.0",
    "lint-staged": "^16.3.3",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.4"
  },
  "overrides": {
    "protobufjs": "7.5.5"
  }
}
